{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": [
            "ES2020"
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "strict": true
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ],
    "exclude": [
        "node_modules",
        "android",
        "ios"
    ]
}