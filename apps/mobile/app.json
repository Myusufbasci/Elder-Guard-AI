{
    "expo": {
        "name": "Elder-Guard Mobile",
        "slug": "elder-guard-mobile",
        "version": "0.0.1",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "scheme": "elder-guard",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#0ea5e9"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.elderguard.mobile",
            "infoPlist": {
                "UIBackgroundModes": ["fetch", "processing"]
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#0ea5e9"
            },
            "package": "com.elderguard.mobile"
        },
        "plugins": [
            "expo-router",
            "expo-sensors",
            [
                "expo-notifications",
                {
                    "icon": "./assets/icon.png",
                    "color": "#0ea5e9"
                }
            ],
            [
                "expo-background-fetch",
                {
                    "stopOnTerminate": false,
                    "startOnBoot": true
                }
            ]
        ]
    }
}