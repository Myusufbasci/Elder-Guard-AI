# Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://eldercare:eldercare_dev_password@localhost:5432/eldercare_dev

# Redis/Valkey
REDIS_URL=redis://localhost:6379

# JWT — three separate secrets per AGENTS.md Rule 3 ("No shared secret across purposes")
# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_refresh_secret_at_least_32_chars
JWT_PAIRING_SECRET=replace_me_pairing_secret_at_least_32_chars

# Token TTLs
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=30d
JWT_PAIRING_TTL=15m

# Bcrypt cost factor (work factor; 12 ~ 250ms hash on a modern CPU)
BCRYPT_ROUNDS=12

# Firebase
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# Google OAuth Client ID (from Firebase Console → Authentication → Sign-in method → Google)
GOOGLE_CLIENT_ID=

# Google Gemini AI
GEMINI_API_KEY=

# NestJS App
APP_PORT=3000
APP_HOST=0.0.0.0

# Logging
LOG_LEVEL=debug
