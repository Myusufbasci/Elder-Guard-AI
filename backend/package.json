{
  "name": "eldercare-backend",
  "version": "0.0.1",
  "description": "ElderCare remote health monitoring backend",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "prisma": {
    "schema": "prisma/schema"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --forceExit --detectOpenHandles",
    "test:docker": "docker compose -f docker-compose.test.yml run --rm test-runner",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.0",
    "@nestjs/bullmq": "11.0.2",
    "@nestjs/common": "11.0.0",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.0.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.0",
    "@nestjs/schedule": "5.0.1",
    "@nestjs/terminus": "11.0.0",
    "@nestjs/throttler": "6.5.0",
    "@prisma/client": "6.1.0",
    "bcrypt": "5.1.1",
    "bullmq": "5.34.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "express": "4.21.2",
    "firebase-admin": "12.7.0",
    "google-auth-library": "9.14.1",
    "ioredis": "5.4.1",
    "joi": "17.13.3",
    "nestjs-pino": "4.1.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "reflect-metadata": "0.2.1",
    "rimraf": "6.0.1",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.2",
    "@nestjs/testing": "11.0.0",
    "@types/bcrypt": "5.0.2",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "22.12.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "8.13.0",
    "@typescript-eslint/parser": "8.13.0",
    "eslint": "9.14.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "prisma": "6.1.0",
    "supertest": "7.0.0",
    "ts-jest": "29.1.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1"
  }
}
