// Authentication and user models — aligned to INTEGRATION.md DB Schema Outline
// and REVERSE_ENGINEERING_DOC Cross-Repository Synthesis Section 1.

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  // null for elder accounts created by caregiver (paired flow)
  role         UserRole
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 1:1 child profile tables — never branch on role string in service code (AGENTS.md Rule 9)
  caregiverProfile CaregiverProfile?
  elderProfile     ElderProfile?
  pushTokens       PushToken[]
  notifications    NotificationLog[]
  auditLogs        AuditLog[]

  @@map("users")
}

model CaregiverProfile {
  userId    String   @id @db.Uuid
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  careLinks CareLink[]

  @@map("caregiver_profiles")
}

model ElderProfile {
  userId      String   @id @db.Uuid
  dateOfBirth DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  careLinks CareLink[]
  devices   Device[]
  pairings  DevicePairing[]
  anomalies AnomalyEvent[]

  @@map("elder_profiles")
}

// Composite PK enables Prisma's `caregiverId_elderId` compound filter used by CareLinkGuard.
model CareLink {
  caregiverId String   @db.Uuid
  elderId     String   @db.Uuid
  createdAt   DateTime @default(now())

  caregiver CaregiverProfile @relation(fields: [caregiverId], references: [userId], onDelete: Cascade)
  elder     ElderProfile     @relation(fields: [elderId], references: [userId], onDelete: Cascade)

  @@id([caregiverId, elderId])
  @@index([elderId])
  @@map("care_links")
}
